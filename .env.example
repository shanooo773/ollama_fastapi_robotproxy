# Service
SERVICE_NAME=ollama-fastapi-robot-proxy

# Ollama endpoints
OLLAMA_LOCAL_BASE_URL=http://localhost:11434
OLLAMA_REMOTE_URLS=http://REMOTE_SERVER_IP:11434

# Routing and fallback
REMOTE_PRIMARY_MODEL=qwen2.5:7b-instruct
REMOTE_SECONDARY_MODEL=llama3.1:8b-instruct
LOCAL_FALLBACK_MODEL=qwen2.5:1.5b-instruct

# Optional mode/model routing
CODE_MODEL=deepseek-coder:6.7b
EMBEDDING_MODEL=nomic-embed-text
VISION_MODEL=llava:7b

# Network behavior
REQUEST_TIMEOUT_SECONDS=45
HEALTH_TIMEOUT_SECONDS=3
MAX_RETRIES=1
